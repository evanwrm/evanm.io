{
    "name": "evanm.io",
    "version": "0.1.0",
    "private": true,
    "description": "Evan's personal portfolio website",
    "keywords": [
        "portfolio",
        "nextjs",
        "sanity"
    ],
    "homepage": "https://evanm.io",
    "bugs": {
        "url": "https://github.com/evanwrm/evanm.io/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/evanwrm/evanm.io"
    },
    "license": "MIT",
    "author": "Evan Madill <emadill@outlook.com>",
    "scripts": {
        "g:lint": "run-p g:format-check g:lint-check",
        "g:lint-check": "pnpm -r --parallel run lint",
        "g:format-check": "prettier --check .",
        "g:format-fix": "prettier --write .",
        "g:changeset": "changeset",
        "g:clean": "rm -rf pnpm-lock.yaml node_modules && pnpm -r --parallel exec rm -rf pnpm-lock.yaml node_modules",
        "turbo:dev": "turbo run dev",
        "turbo:build": "turbo run build",
        "turbo:start": "turbo run start",
        "turbo:test": "turbo run test",
        "turbo:lint": "turbo run lint",
        "deps:update": "pnpm up -irL",
        "lint-staged": "lint-staged",
        "prepare": "is-ci || husky install"
    },
    "devDependencies": {
        "@babel/core": "^7.22.11",
        "@babel/eslint-parser": "^7.22.11",
        "@changesets/cli": "^2.26.2",
        "@commitlint/cli": "^17.7.1",
        "@commitlint/config-conventional": "^17.7.0",
        "@types/node": "^20.5.6",
        "cross-env": "^7.0.3",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^8.0.3",
        "is-ci": "^3.0.1",
        "lint-staged": "^14.0.1",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.0.2",
        "prettier-plugin-packagejson": "^2.4.5",
        "shell-quote": "^1.8.1",
        "turbo": "^1.10.13",
        "typescript": "5.2.2"
    },
    "packageManager": "pnpm@8.5.1",
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.5.1"
    }
}
