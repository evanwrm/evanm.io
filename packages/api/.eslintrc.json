{
    "parser": "@babel/eslint-parser",
    "extends": ["eslint:recommended", "prettier"],
    "env": {
        "commonjs": true,
        "node": true,
        "es6": true,
        "browser": false
    },
    "parserOptions": {
        "requireConfigFile": false,
        "ecmaFeatures": {
            "experimentalObjectRestSpread": true,
            "jsx": false
        },
        "sourceType": "module"
    },
    "globals": {
        "strapi": true
    }
}
