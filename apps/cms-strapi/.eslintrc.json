{
    "$schema": "https://json.schemastore.org/eslintrc",
    "root": true,
    "parser": "@babel/eslint-parser",
    "extends": ["eslint:recommended", "prettier"],
    "env": {
        "commonjs": true,
        "node": true,
        "es6": true,
        "browser": false
    },
    "parserOptions": {
        "requireConfigFile": false,
        "sourceType": "module",
        "ecmaFeatures": {
            "experimentalObjectRestSpread": true,
            "jsx": false
        }
    },
    "globals": {
        "strapi": true
    }
}
