{
    "kind": "collectionType",
    "collectionName": "articles",
    "info": {
        "singularName": "article",
        "pluralName": "articles",
        "displayName": "Article",
        "description": ""
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "slug": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "description": {
            "type": "text"
        },
        "content": {
            "type": "richtext"
        },
        "tags": {
            "type": "component",
            "repeatable": true,
            "component": "article.tag"
        },
        "thumbnail": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "media": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": ["images", "files", "videos", "audios"]
        },
        "statsTime": {
            "type": "integer",
            "default": 0
        },
        "statsWords": {
            "type": "integer",
            "default": 0
        }
    }
}
