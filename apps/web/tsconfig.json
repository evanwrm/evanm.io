{
    "extends": "astro/tsconfigs/strict",
    "include": [
        ".astro/types.d.ts",
        "**/*.astro",
        "**/*.ts",
        "**/*.tsx",
        "**/*.js"
    ],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "plugins": [{ "name": "@astrojs/ts-plugin" }]
    }
}
