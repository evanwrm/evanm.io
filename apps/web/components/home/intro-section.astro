---
import {
    ArrowRightIcon,
    CalendarIcon,
    ChevronDownIcon,
    FileTextIcon,
} from "lucide-react";
import { Image } from "@/components/image";
import { ButtonLink } from "@/components/link";
import { Markdown } from "@/components/mdx/markdown";
import { useTranslations } from "@/lib/i18n";
import { isReference } from "@/lib/sanity/utils";
import type { Home } from "@/lib/validators/home";
import type { Settings } from "@/lib/validators/settings";
import { Button } from "@/components/ui/button";

interface Props {
    home: Home;
    settings: Settings;
}

const { home, settings } = Astro.props;
const { t } = useTranslations();
const authorName = `${settings.firstName} ${settings.lastName}`;
const hasAvatar =
    settings.avatar && !isReference(settings.avatar?.asset);
---

<section
    id="intro"
    class="relative mx-auto flex min-h-[calc(100dvh-4rem)] w-full max-w-5xl items-center p-4"
>
    <div class="transition duration-500 ease-spring motion-safe:md:opacity-0 motion-safe:md:translate-y-20 motion-safe:md:intersect:opacity-100 motion-safe:md:intersect:translate-y-0 intersect-once intersect-quarter -mt-16 w-full text-left">
        <div class="grid items-center grid-cols-[1fr_auto] gap-x-5 gap-y-6 sm:gap-x-8 md:gap-x-14 md:gap-y-0 [grid-template-areas:'heading_avatar'_'intro_intro'_'actions_actions'] md:[grid-template-areas:'heading_avatar'_'intro_avatar'_'actions_avatar']">
            <div class="min-w-0 [grid-area:heading]">
                <h1 class="text-balance font-extrabold text-4xl tracking-tight lg:text-5xl">
                    {home.heading}
                </h1>
                {home.logline && (
                    <p class="mt-3 inline-block bg-linear-to-r from-red-600/80 via-rose-500/80 to-orange-500/80 bg-clip-text text-sm font-semibold uppercase tracking-[0.15em] text-transparent">
                        {home.logline}
                    </p>
                )}
            </div>
            {home.intro && (
                <div class="[grid-area:intro] md:mt-6">
                    <Markdown
                        source={home.intro}
                        className="text-muted-foreground"
                    />
                </div>
            )}
            <div class="flex flex-wrap items-center gap-3 [grid-area:actions] md:mt-8">
                <ButtonLink
                    href="/resume"
                    variant="outline"
                    size="lg"
                    className="group border-none rounded-full hover:-translate-y-0.5"
                >
                    <FileTextIcon className="group-hover:scale-110" />
                    {t("resumeRequest.cta")}
                </ButtonLink>
                {settings.bookingUrl && (
                    <ButtonLink
                        href={settings.bookingUrl}
                        variant="outline"
                        size="lg"
                        className="group border-none rounded-full hover:-translate-y-0.5"
                    >
                        <CalendarIcon className="group-hover:-rotate-12" />
                        {t("common.bookAppointment")}
                        <ArrowRightIcon className="group-hover:translate-x-0.5" />
                    </ButtonLink>
                )}
            </div>
            {hasAvatar && settings.avatar && !isReference(settings.avatar.asset) && (
                <div class="flex justify-end self-end [grid-area:avatar]">
                    <Image
                        src={settings.avatar.asset}
                        alt={settings.avatar.alt ?? authorName}
                        width={384}
                        height={384}
                        fetchPriority="high"
                        className="h-20 w-20 select-none rounded-full shadow-md ring-2 ring-transparent ring-offset-4 ring-offset-background transition-all duration-500 will-change-transform hover:scale-105 hover:ring-ring/20 md:h-48 md:w-48"
                    />
                </div>
            )}
        </div>
    </div>
    <Button
        id="intro-view-more"
        variant="ghost"
        size="icon-lg"
        aria-label={t("nav.viewMore")}
        className="group pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2 rounded-full opacity-0 transition-opacity duration-500 hover:text-foreground motion-safe:animate-bounce"
    >
        <ChevronDownIcon className="size-6 transition group-hover:translate-y-0.5" />
    </Button>
</section>

<script>
    const btn = document.getElementById("intro-view-more");
    if (btn) {
        const revealDelayMs = 3000;

        const reveal = () => {
            btn.classList.remove("pointer-events-none", "opacity-0");
            btn.classList.add("opacity-100");
        };
        const hide = () => {
            btn.classList.add("pointer-events-none", "opacity-0");
            btn.classList.remove("opacity-100");
        };

        const timer = setTimeout(reveal, revealDelayMs);

        window.addEventListener(
            "scroll",
            () => {
                if (window.scrollY > 0) {
                    clearTimeout(timer);
                    hide();
                }
            },
            { passive: true, once: true },
        );

        btn.addEventListener("click", () => {
            const intro = document.getElementById("intro");
            if (!intro) return;
            const sections = Array.from(document.querySelectorAll("section"));
            const next = sections[sections.indexOf(intro) + 1];
            next?.scrollIntoView({ behavior: "smooth", block: "start" });
            hide();
        });
    }
</script>
