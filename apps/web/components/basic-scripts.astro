---
import { THEME_CHANGE_EVENT, THEME_STORAGE_KEY } from "@/lib/theme";
---

<!-- Theme -->
<script
    is:inline
    define:vars={{ themeChangeEvent: THEME_CHANGE_EVENT, themeStorageKey: THEME_STORAGE_KEY }}
>
    const media = window.matchMedia("(prefers-color-scheme: dark)");

    const getTheme = () => localStorage.getItem(themeStorageKey) || "system";
    const applyTheme = (theme) => {
        const resolvedTheme =
            theme === "dark" ||
            (theme === "system" && media.matches)
                ? "dark"
                : "light";

        const event = new CustomEvent(themeChangeEvent, { detail: { theme, resolvedTheme } });
        document.documentElement.classList.toggle("dark", resolvedTheme === "dark");
        window.dispatchEvent(event);
    };

    applyTheme(getTheme());

    media.addEventListener("change", () => {
        if (getTheme() === "system") applyTheme("system");
    });
</script>

<!-- Intersection Observer (https://github.com/heidkaemper/tailwindcss-intersect) -->
<script is:inline>
    const getThreshold = element => {
        if (element.classList.contains("intersect-full")) return 0.99;
        if (element.classList.contains("intersect-half")) return 0.5;
        if (element.classList.contains("intersect-quarter")) return 0.25;
        return 0;
    };

    const Observer = {
        observer: null,
        elements: null,

        start() {
            this.observer?.disconnect();

            const selectors = [
                '[class*=" intersect:"]',
                '[class*=":intersect:"]',
                '[class^="intersect:"]',
                '[class="intersect"]',
                '[class*=" intersect "]',
                '[class^="intersect "]',
                '[class$=" intersect"]',
            ];
            this.elements = Array.from(
                document.querySelectorAll(selectors.join(",")),
            );

            this.elements.forEach(el => {
                el.setAttribute("no-intersect", "");
                el._intersectionThreshold = getThreshold(el);
            });

            this.observer = new IntersectionObserver(
                entries => {
                    for (const entry of entries) {
                        const target = entry.target;
                        const threshold = target._intersectionThreshold;

                        if (
                            entry.isIntersecting &&
                            entry.intersectionRatio >= threshold
                        ) {
                            target.removeAttribute("no-intersect");
                            if (target.classList.contains("intersect-once")) {
                                this.observer.unobserve(target);
                            }
                        } else if (!entry.isIntersecting) {
                            target.setAttribute("no-intersect", "");
                        }
                    }
                },
                { threshold: [0, 0.25, 0.5, 0.99] },
            );

            this.elements.forEach(el => {
                this.observer.observe(el);
            });
        },
    };

    Observer.start();

    document.addEventListener("astro:after-swap", () => {
        Observer.start();
    });
</script>

<!-- Code copy button -->
<script>
    const copyResetTimers = new WeakMap<HTMLElement, number>();

    document.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest<HTMLElement>("[data-copy-button]");
        if (!button) return;

        const root = button.closest("[data-code-block]");
        const pre = root?.querySelector("pre");
        const copyIcon = button.querySelector<HTMLElement>("[data-copy-icon]");
        const checkIcon = button.querySelector<HTMLElement>("[data-check-icon]");
        if (!pre || !copyIcon || !checkIcon) return;

        try {
            await navigator.clipboard.writeText(pre.textContent ?? "");
        } catch {
            return;
        }

        const existingTimer = copyResetTimers.get(button);
        if (existingTimer) window.clearTimeout(existingTimer);

        copyIcon.classList.add("scale-0", "opacity-0");
        checkIcon.classList.remove("scale-0", "opacity-0");
        checkIcon.classList.add("opacity-100");

        const timer = window.setTimeout(() => {
            checkIcon.classList.remove("opacity-100");
            checkIcon.classList.add("scale-0", "opacity-0");
            copyIcon.classList.remove("scale-0", "opacity-0");
            copyResetTimers.delete(button);
        }, 2000);

        copyResetTimers.set(button, timer);
    });
</script>
