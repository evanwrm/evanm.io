---
import BaseLayout from "./base-layout.astro";
import Header from "@/components/header.astro";
import Footer from "@/components/footer.astro";
import BackToTop from "@/components/back-to-top.astro";
import HexBackground from "@/components/hex-background.astro";
import { useTranslations } from "@/lib/i18n";
import { socialFind } from "@/lib/sanity/queries";

interface Props {
    showHexBackground?: boolean;
}

const { showHexBackground = true } = Astro.props;
const { t } = useTranslations();
const headerRoutes = [
    { href: "/", label: t("common.home") },
    { href: "/blog", label: t("common.blog") },
];

const socials = await socialFind();
---

<BaseLayout>
    <slot slot="head" name="head" />
    {showHexBackground && <HexBackground class="h-48 text-foreground/40" />}
    <Header routes={headerRoutes} socials={socials} />
    <main class="flex flex-1 flex-col">
        <slot />
    </main>
    <BackToTop />
    <Footer routes={headerRoutes} socials={socials} />
</BaseLayout>
