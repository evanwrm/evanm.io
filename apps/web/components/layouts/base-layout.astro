---
import { Font } from "astro:assets";
import Analytics from "@/components/analytics/analytics.astro";
import ScriptsBody from "@/components/scripts-body.astro";
import ScriptsHead from "@/components/scripts-head.astro";
import { useTranslations } from "@/lib/i18n";
import "@/styles/globals.css";

const { locale, dir } = useTranslations();
---

<!doctype html>
<html lang={locale} dir={dir} class="scroll-smooth">
    <head>
        <!-- Meta -->
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />

        <!-- Seo -->
        <slot name="head" />
        
        <!-- Fonts -->
        <Font cssVariable="--font-sans" />
        <Font cssVariable="--font-mono" />

        <!-- 4. Theme Colors -->
        <meta name="theme-color" content="#000" media="(prefers-color-scheme: dark)" />
        <meta name="theme-color" content="#fff" media="(prefers-color-scheme: light)" />
        <meta name="color-scheme" content="dark light" />
        
        <ScriptsHead />

        <!-- Low Meta -->
        <meta name="application-name" content="evanm.io Portfolio" />
        <meta name="referrer" content="origin-when-cross-origin" />
        <meta name="format-detection" content="telephone=no, address=no, email=no" />
        <meta name="generator" content={Astro.generator} />

        <!-- Favicons -->
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/static/favicons/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/static/favicons/favicon-16x16.png"
        />
        <link rel="shortcut icon" href="/static/favicons/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/static/favicons/apple-touch-icon.png"
        />
        <link
            rel="apple-touch-icon-precomposed"
            href="/static/favicons/apple-touch-icon-precomposed.png"
        />
        <link rel="mask-icon" href="/static/favicons/safari-pinned-tab.svg" />
        <link rel="manifest" href="/manifest.json" />

        <!-- Apple Web App -->
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-title" content="evanm.io Portfolio" />
        <meta name="apple-mobile-web-app-status-bar-style" content="default" />
        <link
            rel="apple-touch-startup-image"
            href="/static/favicons/apple-touch-icon.png"
        />
    </head>
    <body class="scrollbar bg-background text-foreground transition duration-150">
        <div
            vaul-drawer-wrapper=""
            class="relative flex min-h-screen flex-col overflow-clip bg-background"
        >
            <Analytics />
            <slot />
        </div>
        <ScriptsBody />
    </body>
</html>
