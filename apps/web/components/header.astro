---
import { HeaderSpotlight } from "@/components/header-spotlight";
import { Link } from "@/components/link";
import { MainNav } from "@/components/main-nav";
import { MobileNav } from "@/components/mobile-nav";
import type { SocialLink } from "@/lib/validators/social";

interface Props {
    routes: { href: string; label: string }[];
    socials: SocialLink[];
}

const { routes, socials } = Astro.props;
const siteUrl = Astro.site?.origin ?? "https://evanm.io";
const pathname = Astro.url.pathname;
---

<header
    id="main-header"
    class="sticky top-0 z-40 flex h-16 items-center justify-between px-4 transition-all border-transparent bg-transparent"
>
    <div class="flex items-center gap-2">
        <MobileNav links={routes} pathname={pathname} client:idle />
        <Link
            href="/"
            aria-label="evanm.io"
            className="font-bold text-foreground/80 transition-all hover:text-foreground"
        >
            <span>evanm</span>
            <span class="text-red-600">.io</span>
        </Link>
        <MainNav links={routes} pathname={pathname} className="ml-8" />
    </div>
    <div class="flex items-center gap-2 sm:gap-4">
        <HeaderSpotlight
            socials={socials}
            siteUrl={siteUrl}
            client:idle
        />
    </div>
</header>

<script>
    const header = document.getElementById("main-header");
    if (header) {
        const threshold = 80;
        const showThreshold = 60;
        const scrolledClasses = [
            "border-border/60",
            "border-b",
            "bg-background/60",
            "bg-clip-padding",
            "backdrop-blur",
            "backdrop-saturate-200",
        ];
        const topClasses = ["border-transparent", "bg-transparent"];
        const hiddenClasses = [
            "pointer-events-none",
            "scale-[102%]",
            "select-none",
            "opacity-0",
        ];

        let lastY = window.scrollY;
        let travel = 0;

        const updateScrolledState = (y: number) => {
            const scrolled = y > 196;
            for (const c of scrolledClasses)
                header.classList.toggle(c, scrolled);
            for (const c of topClasses) 
                header.classList.toggle(c, !scrolled);
        };

        const setHidden = (hidden: boolean) => {
            for (const c of hiddenClasses) 
                header.classList.toggle(c, hidden);
        };

        const onScroll = () => {
            const y = window.scrollY;
            const delta = y - lastY;
            lastY = y;

            updateScrolledState(y);
            if (y < showThreshold) {
                travel = 0;
                setHidden(false);
                return;
            }

            travel += delta;
            if (travel > threshold) {
                setHidden(true);
                travel = 0;
            } else if (travel < -threshold) {
                setHidden(false);
                travel = 0;
            }
        };

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
    }
</script>
