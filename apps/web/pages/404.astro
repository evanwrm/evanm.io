---
import { MoveLeftIcon } from "lucide-react";
import BaseLayout from "@/components/layouts/base-layout.astro";
import { ButtonLink } from "@/components/link";
import SeoPage from "@/components/seo-page.astro";
import { useTranslations } from "@/lib/i18n";

const { t } = useTranslations();
---

<BaseLayout>
    <SeoPage
        slot="head"
        title={t("error.notFoundTitle")}
        noindex={true}
        nofollow={true}
    />
    <div class="flex min-h-[calc(100dvh-4rem)] flex-col items-center justify-center p-4 text-center">
        <div class="transition duration-500 ease-spring motion-safe:md:opacity-0 motion-safe:md:translate-y-20 motion-safe:md:intersect:opacity-100 motion-safe:md:intersect:translate-y-0 intersect-once intersect-quarter flex flex-col items-center gap-6">
            <h1 class="font-bold font-mono text-8xl text-muted-foreground/20">
                404
            </h1>
            <div class="space-y-2">
                <h2 class="font-bold text-2xl tracking-tight">
                    {t("error.notFoundHeading")}
                </h2>
                <p class="text-muted-foreground">
                    {t("error.notFoundDescription")}
                </p>
            </div>
            <ButtonLink href="/" variant="link" className="mt-4 gap-2">
                <MoveLeftIcon className="size-4" />
                {t("nav.backToHome")}
            </ButtonLink>
        </div>
    </div>
</BaseLayout>
