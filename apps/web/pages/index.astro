---
import EducationSection from "@/components/home/education-section.astro";
import ExperienceSection from "@/components/home/experience-section.astro";
import IntroSection from "@/components/home/intro-section.astro";
import ProjectsSection from "@/components/home/projects-section.astro";
import PublicationsSection from "@/components/home/publications-section.astro";
import SectionToc from "@/components/home/section-toc";
import MainLayout from "@/components/layouts/main-layout.astro";
import SeoPage from "@/components/seo-page.astro";
import { useTranslations } from "@/lib/i18n";
import {
    educationFind,
    experienceFind,
    homeFind,
    projectFind,
    publicationFind,
    settingsFind,
} from "@/lib/sanity/queries";

export const prerender = false;
const { t } = useTranslations();

const [home, educations, experiences, projects, publications, settings] =
    await Promise.all([
        homeFind(),
        educationFind({ sort: ["endDate desc", "startDate desc"] }),
        experienceFind({ sort: ["endDate desc", "startDate desc"] }),
        projectFind({ sort: "endDate desc" }),
        publicationFind({ sort: "year desc" }),
        settingsFind(),
    ]);
---

<MainLayout>
    <SeoPage slot="head" title={t("common.home")} />
    {home.includeIntro && (
        <IntroSection home={home} settings={settings} />
    )}
    <div class="mx-auto flex w-full max-w-7xl gap-8 p-4">
        <div class="min-w-0 flex-1 space-y-16">
            {home.includeExperience && (
                <ExperienceSection experiences={experiences} />
            )}
            {home.includeEducation && (
                <EducationSection educations={educations} />
            )}
            {home.includeProjects && (
                <ProjectsSection projects={projects} />
            )}
            {home.includePublications && (
                <PublicationsSection publications={publications} />
            )}
        </div>
        <aside class="sticky top-24 hidden w-48 shrink-0 self-start xl:block">
            <SectionToc client:idle />
        </aside>
    </div>
</MainLayout>
