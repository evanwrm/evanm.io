---
import MainLayout from "@/components/layouts/main-layout.astro";
import { ResumeRequestForm } from "@/components/resume-request-form";
import SeoPage from "@/components/seo-page.astro";
import { useTranslations } from "@/lib/i18n";

export const prerender = false;
const { t } = useTranslations();
---

<MainLayout>
    <SeoPage
        slot="head"
        title={t("resumeRequest.pageTitle")}
        description={t("resumeRequest.pageDescription")}
        noindex
    />
    <div class="mx-auto w-full max-w-xl px-4 py-12">
        <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-3">
                <h1 class="text-balance font-semibold text-3xl tracking-tight">
                    {t("resumeRequest.heading")}
                </h1>
                <p class="text-muted-foreground text-sm leading-relaxed">
                    {t("resumeRequest.intro")}
                </p>
            </div>
            <ResumeRequestForm client:load />
        </div>
    </div>
</MainLayout>
