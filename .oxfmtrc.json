{
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 80,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "semi": true,
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "sortTailwindcss": { "functions": ["clsx", "cn", "cva", "tw"] },
    "sortImports": { "newlinesBetween": false }
}
